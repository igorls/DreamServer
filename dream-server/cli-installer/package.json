{
  "name": "dream-installer",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/dream-installer",
    "build:arm": "bun build --compile --target=bun-linux-arm64 src/index.ts --outfile dist/dream-installer-arm64",
    "build:win": "bun build --compile --target=bun-windows-x64 src/index.ts --outfile dist/dream-installer.exe",
    "test": "bun test"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10"
  }
}
