{
  "name": "dreamserver-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1421",
    "build": "tsc && vite build",
    "build:proxy": "bun build --compile src/proxy.ts --outfile src-tauri/binaries/dreamserver-proxy-$(rustc -vV | grep host | cut -d' ' -f2)",
    "build:proxy:linux-x64": "bun build --compile --target=bun-linux-x64 src/proxy.ts --outfile src-tauri/binaries/dreamserver-proxy-x86_64-unknown-linux-gnu",
    "build:proxy:macos-x64": "bun build --compile --target=bun-darwin-x64 src/proxy.ts --outfile src-tauri/binaries/dreamserver-proxy-x86_64-apple-darwin",
    "build:proxy:macos-arm64": "bun build --compile --target=bun-darwin-arm64 src/proxy.ts --outfile src-tauri/binaries/dreamserver-proxy-aarch64-apple-darwin",
    "build:proxy:windows-x64": "bun build --compile --target=bun-windows-x64 src/proxy.ts --outfile src-tauri/binaries/dreamserver-proxy-x86_64-pc-windows-msvc.exe",
    "build:all": "bun run build:proxy && bun run build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "universal-llm-client": "^4.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
